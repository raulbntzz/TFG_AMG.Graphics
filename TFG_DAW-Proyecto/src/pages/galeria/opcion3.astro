---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.tsx";
import BasicMasonry from "../../components/Galeria.tsx";
---

<Layout title="Galería - Opción 3">
	<Navbar client:load />

	<div class="max-w-7xl mx-auto px-4 py-28">
		<div class="text-center mb-12">
			<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Opción 3</h1>
			<p class="text-lg text-gray-600">Explora mis proyectos más recientes</p>
		</div>

		<div class="flex justify-center">
			<BasicMasonry client:load />
		</div>
	</div>
</Layout>
