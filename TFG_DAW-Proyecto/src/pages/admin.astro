---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.tsx";
import AuthGuard from "../components/AuthGuard.tsx";
import AdminGuard from "../components/AdminGuard.tsx";
---

<Layout title="Gestionar Página - AMG.Graphics">
	<AuthGuard client:load />
	<AdminGuard client:load />
	<Navbar client:load />

	<div style="background:var(--bg); min-height:100vh; padding-top:56px;">
		<div style="max-width:1200px; margin:0 auto; padding:4rem 7vw 5rem;">

			<div style="border-top:2px solid var(--accent); margin-bottom:2.5rem;"></div>

			<h1 style="font-family:'LTCBroadway',serif; font-size:clamp(2.2rem,4vw,3.8rem); font-weight:400; color:var(--text); margin:0 0 0.5rem 0; line-height:1.1;">
				Gestionar Página
			</h1>
			<p style="font-family:'Satoshi',sans-serif; font-size:1.05rem; color:var(--text); opacity:0.6; margin:0 0 3.5rem 0;"></p>

			<div class="admin-cards-grid">
				<a href="/admin/galeria" class="admin-card" style="display:block; background:#111111; border:1px solid var(--border-subtle); padding:2.5rem 2rem; text-decoration:none;">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFF4E6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:1.25rem; display:block;">
						<rect x="3" y="3" width="18" height="18"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
					</svg>
					<h3 style="font-family:'LTCBroadway',serif; font-size:1.4rem; font-weight:400; color:#FFF4E6; margin:0 0 0.75rem 0; line-height:1.2;">Galería</h3>
					<p style="font-family:'Satoshi',sans-serif; font-size:0.95rem; color:#FFF4E6; opacity:0.65; margin:0; line-height:1.6;">Añadir, editar o eliminar proyectos de la galería</p>
				</a>

				<a href="/admin/usuarios" class="admin-card" style="display:block; background:#111111; border:1px solid var(--border-subtle); padding:2.5rem 2rem; text-decoration:none;">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFF4E6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:1.25rem; display:block;">
						<circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/><path d="M16 3.13a4 4 0 010 7.75"/><path d="M21 21v-2a4 4 0 00-3-3.87"/>
					</svg>
					<h3 style="font-family:'LTCBroadway',serif; font-size:1.4rem; font-weight:400; color:#FFF4E6; margin:0 0 0.75rem 0; line-height:1.2;">Usuarios</h3>
					<p style="font-family:'Satoshi',sans-serif; font-size:0.95rem; color:#FFF4E6; opacity:0.65; margin:0; line-height:1.6;">Ver y gestionar usuarios registrados</p>
				</a>

				<a href="/admin/mensajes" class="admin-card" style="display:block; background:#111111; border:1px solid var(--border-subtle); padding:2.5rem 2rem; text-decoration:none;">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFF4E6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:1.25rem; display:block;">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
					</svg>
					<h3 style="font-family:'LTCBroadway',serif; font-size:1.4rem; font-weight:400; color:#FFF4E6; margin:0 0 0.75rem 0; line-height:1.2;">Mensajes</h3>
					<p style="font-family:'Satoshi',sans-serif; font-size:0.95rem; color:#FFF4E6; opacity:0.65; margin:0; line-height:1.6;">Ver y responder a mensajes de contacto</p>
				</a>

				<a href="/admin/archivos" class="admin-card" style="display:block; background:#111111; border:1px solid var(--border-subtle); padding:2.5rem 2rem; text-decoration:none;">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FFF4E6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:1.25rem; display:block;">
						<path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
					</svg>
					<h3 style="font-family:'LTCBroadway',serif; font-size:1.4rem; font-weight:400; color:#FFF4E6; margin:0 0 0.75rem 0; line-height:1.2;">Archivos</h3>
					<p style="font-family:'Satoshi',sans-serif; font-size:0.95rem; color:#FFF4E6; opacity:0.65; margin:0; line-height:1.6;">Subir y organizar imágenes y vídeos</p>
				</a>
			</div>

		</div>
	</div>
</Layout>

<style>
.admin-cards-grid {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 2px;
}
.admin-card { transition: background 0.2s, border-color 0.2s; }
.admin-card:hover { background: var(--btn-bg) !important; border-color: var(--btn-bg) !important; }

@media (max-width: 768px) {
	.admin-cards-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
	.admin-cards-grid { grid-template-columns: 1fr; }
}
</style>