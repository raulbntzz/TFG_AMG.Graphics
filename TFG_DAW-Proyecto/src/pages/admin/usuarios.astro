---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.tsx";
import AuthGuard from "../../components/AuthGuard.tsx";
import AdminGuard from "../../components/AdminGuard.tsx";
import UserManagement from "../../components/UserManagement.tsx";
---

<Layout title="Gestionar Usuarios - AMG.Graphics">
	<AuthGuard client:load />
	<AdminGuard client:load />
	<Navbar client:load />

	<div class="max-w-7xl mx-auto pt-28 pb-8 md:pb-16">
		<div class="px-4 md:px-8 mb-8">
			<a href="/admin" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-3 py-2 rounded-lg flex items-center gap-2 transition-colors">
				<i class="fa-solid fa-arrow-left text-xs"></i> Volver
			</a>
		</div>

		<div class="px-4 md:px-8">
			<div class="text-center mb-12">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4"><i class="fa-solid fa-users"></i> Gestionar Usuarios</h1>
				<p class="text-lg text-gray-600">Ver, editar y eliminar usuarios registrados</p>
			</div>

			<UserManagement client:load />
		</div>
	</div>
</Layout>
